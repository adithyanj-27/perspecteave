# Supabase Configuration
# Copy this file to .env and fill in your actual Supabase URL and Public Anon Key.
# Find these in Supabase Dashboard -> Project Settings -> API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The email address that has admin access (to write new perspectives)
VITE_ADMIN_EMAIL=your-admin-email@example.com

# VAPID Keys for Web Push Notifications
VITE_VAPID_PUBLIC_KEY=BMMdv7F4CsfOFKFeWReqhDG1z-S4CbFYiJpvVTtGmZ6aRTER945-LhFabNsd4U_KVcZsSFCxznFX5LqaR3F3VTY
VITE_VAPID_PRIVATE_KEY=your-vapid-private-key-here
